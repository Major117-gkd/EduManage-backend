# Base de données
DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@localhost:5432/postgres?schema=public"

# Sécurité JWT (obligatoire en production)
JWT_SECRET="changez-moi-en-production"

# ── E-mail SMTP (optionnel — peut aussi être configuré dans Paramètres du site) ──
# Gmail : smtp.gmail.com, port 587, créer un mot de passe d'application Google
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=votre.email@gmail.com

# URL du site (lien « Se connecter » dans les e-mails professeurs)
FRONTEND_URL=http://localhost:5173
