// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id           Int      @id @default(autoincrement())
  nom          String
  email        String   @unique
  mot_de_passe String
  role         String   // ADMIN, COMPTABLE, DIRECTEUR, PROFESSEUR, ELEVE, PARENT
  perimetre    String?  // Primaire, Collège, Lycée — pour DIRECTEUR
  photoUrl     String?  @db.Text
  eleveId      Int?     @unique
  createdAt    DateTime @default(now())

  professeur     Professeur?
  eleve          Eleve?             @relation(fields: [eleveId], references: [id], onDelete: SetNull)
  parentEnfants  ParentEleveLink[]
  notifications  Notification[]
}

model ParentEleveLink {
  id            Int         @id @default(autoincrement())
  utilisateurId Int
  eleveId       Int
  createdAt     DateTime    @default(now())

  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  eleve         Eleve       @relation(fields: [eleveId], references: [id], onDelete: Cascade)

  @@unique([utilisateurId, eleveId])
  @@index([eleveId])
}

model Eleve {
  id              Int           @id @default(autoincrement())
  matricule       String        @unique
  nom             String
  prenom          String
  photoUrl        String?       @db.Text
  date_naissance  DateTime?
  adresse         String?
  parent_nom      String?
  parent_telephone String?
  parent_email    String?
  filiation       String?       // e.g. "Père", "Mère", "Tuteur"
  infos_importantes String?     // e.g. "Allergique à l'arachide", "Asthme"
  solde           Float         @default(0)  // Montant dû par l'élève
  statut_financier String       @default("En attente")  // "À jour", "En retard", "À jour partiel", "En attente"
  exception_paiement_mensuel Boolean @default(false) // Si true, paiement mensuel autorisé au lieu de tranches de 3 mois
  inscriptions    Inscription[]
  notes           Note[]
  resultats       Resultat[]
  paiements       Paiement[]
  statut          String        @default("Actif") // Actif, Abandon, Transféré, Exclu
  date_abandon    DateTime?
  motif_abandon   String?
  createdAt       DateTime      @default(now())
  utilisateur     Utilisateur?
  parentLiens     ParentEleveLink[]
}

model Professeur {
  id             Int          @id @default(autoincrement())
  utilisateurId  Int          @unique
  nom            String
  prenom         String
  specialite     String?
  contact        String?
  photoUrl       String?      @db.Text
  matieres       Matiere[]
  presences      PresenceProfesseur[]
  createdAt      DateTime     @default(now())

  utilisateur    Utilisateur  @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model AnneeScolaire {
  id        Int      @id @default(autoincrement())
  nom       String   @unique // ex: 2024-2025
  active    Boolean  @default(false)
  classes   Classe[]
  createdAt DateTime @default(now())
}

model Classe {
  id           Int           @id @default(autoincrement())
  nom          String        // ex: 6ème A
  niveau       String        // ex: 6ème
  cycle        String        @default("Collège") // Primaire, Collège, Lycée
  capacite        Int           @default(30)
  montant_annuel Float        @default(0) // Montant annuel fixe pour cette classe (ex: 900000 FCFA pour 9 mois)
  anneeScolaireId Int?
  niveauEtudeId   Int?
  anneeScolaire   AnneeScolaire? @relation(fields: [anneeScolaireId], references: [id])
  niveauEtude     NiveauEtude?   @relation(fields: [niveauEtudeId], references: [id])
  inscriptions    Inscription[]
  matieres        Matiere[]
  resultats       Resultat[]
  tranches        TrancheClasse[]
  tarifHoraire    TarifHoraireClasse?
  presencesProf   PresenceProfesseur[]
  createdAt       DateTime      @default(now())
}

model NiveauEtude {
  id          Int      @id @default(autoincrement())
  nom         String   @unique
  cycle       String   // Primaire, Collège, Lycée
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  regleCalcul Json
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Classe[]
}

model TrancheClasse {
  id          Int       @id @default(autoincrement())
  nom         String    // ex: "Frais d'inscription", "Tranche 1"
  montant     Float
  date_limite DateTime? 
  classeId    Int
  classe      Classe    @relation(fields: [classeId], references: [id], onDelete: Cascade)
}

model Inscription {
  id             Int      @id @default(autoincrement())
  eleveId        Int
  classeId       Int
  annee_scolaire String   // ex: 2023-2024
  statut         String   // En attente, Validé, Rejeté
  motif_rejet    String?
  date_demande   DateTime @default(now())

  eleve          Eleve    @relation(fields: [eleveId], references: [id])
  classe         Classe   @relation(fields: [classeId], references: [id])
}

model Matiere {
  id               Int         @id @default(autoincrement())
  nom              String
  coefficient      Float       @default(1)
  professeurId     Int?
  classeId         Int?
  catalogMatiereId Int?
  notes            Note[]
  presences        PresenceProfesseur[]

  professeur       Professeur?  @relation(fields: [professeurId], references: [id])
  classe           Classe?      @relation(fields: [classeId], references: [id])
  catalogMatiere   Matiere?     @relation("MatiereInstances", fields: [catalogMatiereId], references: [id], onDelete: SetNull)
  instances        Matiere[]    @relation("MatiereInstances")
}

model TarifHoraireClasse {
  id            Int      @id @default(autoincrement())
  classeId      Int      @unique
  tarif_horaire Float
  heures_seance Float    @default(1)
  updatedAt     DateTime @updatedAt

  classe        Classe   @relation(fields: [classeId], references: [id], onDelete: Cascade)
}

model PresenceProfesseur {
  id             Int      @id @default(autoincrement())
  professeurId   Int
  matiereId      Int
  classeId       Int
  date_presence  DateTime @db.Date
  nombre_heures  Float    @default(1)
  tarif_horaire  Float
  montant        Float
  annee_scolaire String
  enregistre_par Int?
  createdAt      DateTime @default(now())

  professeur     Professeur @relation(fields: [professeurId], references: [id], onDelete: Cascade)
  matiere        Matiere    @relation(fields: [matiereId], references: [id], onDelete: Cascade)
  classe         Classe     @relation(fields: [classeId], references: [id], onDelete: Cascade)

  @@index([professeurId, annee_scolaire])
  @@index([date_presence])
  @@index([professeurId, classeId, date_presence])
}

model Note {
  id              Int      @id @default(autoincrement())
  valeur          Float    // ex: 15.5
  appreciation    String?
  type_evaluation String   // ex: "Devoir", "Composition"
  periode         String   // ex: "Trimestre 1"
  annee_scolaire  String   // ex: "2024-2025"
  eleveId         Int
  matiereId       Int
  date_saisie     DateTime @default(now())

  eleve           Eleve    @relation(fields: [eleveId], references: [id])
  matiere         Matiere  @relation(fields: [matiereId], references: [id])
}

model Resultat {
  id             Int      @id @default(autoincrement())
  eleveId        Int
  classeId       Int
  annee_scolaire String
  periode        String   // ex: "Trimestre 1", "Annuel"
  moyenne        Float
  appreciation   String?
  createdAt      DateTime @default(now())

  eleve          Eleve    @relation(fields: [eleveId], references: [id])
  classe         Classe   @relation(fields: [classeId], references: [id])
}

model Paiement {
  id              Int      @id @default(autoincrement())
  eleveId         Int
  montant         Float
  mode_paiement   String   // "Espèces", "Chèque", "Virement", "Orange Money", etc.
  periode         String   // "Septembre", "Octobre", "Tranche 1", "Tranche 2", etc.
  date_paiement   DateTime @default(now())
  annee_scolaire  String
  reference       String?  // Numéro de reçu ou référence
  enregistre_par  Int?     // ID de l'utilisateur qui a enregistré le paiement
  notes           String?  // Notes additionnelles
  createdAt       DateTime @default(now())

  eleve           Eleve    @relation(fields: [eleveId], references: [id])
}

model ParametreSite {
  id                 Int      @id @default(1)
  nom_ecole          String   @default("GSP Elhadj Mamadou Saïdou Diallo")
  adresse            String?
  telephone          String?
  email_contact      String?
  devise             String   @default("GNF")
  notif_inscriptions Boolean  @default(true)
  notif_paiements    Boolean  @default(true)
  notif_notes        Boolean  @default(true)
  message_accueil    String?
  mail_enabled       Boolean  @default(false)
  smtp_host          String?  @default("smtp.gmail.com")
  smtp_port          Int?     @default(587)
  smtp_secure        Boolean  @default(false)
  smtp_user          String?
  smtp_app_password  String?
  updatedAt          DateTime @updatedAt
}

model Notification {
  id            Int         @id @default(autoincrement())
  utilisateurId Int
  type          String
  titre         String
  message       String      @db.Text
  lien          String?
  lu            Boolean     @default(false)
  metadata      Json?
  createdAt     DateTime    @default(now())

  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId, lu])
  @@index([utilisateurId, createdAt])
}

model Annonce {
  id        Int      @id @default(autoincrement())
  titre     String
  contenu   String   @db.Text
  categorie String   @default("Info")
  publiee   Boolean  @default(false)
  epinglee  Boolean  @default(false)
  auteurNom String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publiee, epinglee, createdAt])
}
